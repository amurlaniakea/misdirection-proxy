# Misdirection Proxy — Docker Compose Environment
# Copy to .env and customize as needed

# Ollama model to use for benchmarking
# Options: qwen2:0.5b (fast, ~500MB), llama3:8b (better, ~5GB), qwen2:7b
OLLAMA_MODEL=qwen2:0.5b

# Proxy port (host)
PROXY_PORT=8000

# Ollama port (host)
OLLAMA_PORT=11434
